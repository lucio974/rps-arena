{
  "rules": {
    ".read": false,
    ".write": false,

    "presence": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "queue": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null"
      }
    },

    "matches": {
      "$matchId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "invites": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$inviteId": {
          ".write": "auth != null"
        }
      }
    }
  }
}
