/* ============================================================
   RPS ARENA — Firestore Security Rules

   HOW TO APPLY:
   Firebase Console → Build → Firestore Database → Rules tab →
   paste this entire file in, replacing what's there → Publish.

   PHASE 1 (active now): users/ and usernames/ collections.
   PHASE 2–4 (stubbed, commented out): friends, matchmaking, matches.
   Uncomment those blocks as each phase ships — I'll tell you when.

   KNOWN LIMITATION (read this):
   These rules stop other players from reading/writing YOUR documents.
   They do NOT stop a technically savvy player from editing their OWN
   stats (elo, balance, wins...) directly via the Firestore console or
   browser dev tools, since there's no Cloud Function acting as a
   server-side referee. Locking that down fully requires Cloud Functions
   (which need the paid Blaze plan) validating every stat change against
   an actual completed match record. For now, this is "good enough to
   ship and see if it's ever actually a problem" — not bulletproof
   anti-cheat. Flagging this so it's a known tradeoff, not a surprise.
   ============================================================ */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- users/{uid} — the player's profile & stats ----
    // Anyone signed in can READ any profile (needed to show opponent info,
    // leaderboards, friend profiles, etc). Only the profile owner can WRITE
    // to their own doc.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ---- usernames/{lowercaseUsername} — uniqueness index ----
    // Anyone signed in can read (to check availability / resolve a name to
    // a uid). Only creatable once (no overwriting someone else's claimed
    // name), and only by the uid the doc points to.
    match /usernames/{name} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false; // usernames are permanent for now
    }

    // ============================================================
    // PHASE 2 — Friends (uncomment when friends system ships)
    // ============================================================
    // match /friends/{uid}/list/{friendUid} {
    //   allow read: if request.auth != null && request.auth.uid == uid;
    //   allow write: if request.auth != null && request.auth.uid == uid;
    // }
    // match /friendRequests/{requestId} {
    //   allow read: if request.auth != null &&
    //     (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    //   allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
    //   allow update: if request.auth != null && resource.data.toUid == request.auth.uid;
    //   allow delete: if request.auth != null &&
    //     (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    // }

    // ============================================================
    // PHASE 3 — Matchmaking + live matches (uncomment when it ships)
    // ============================================================
    // match /matchmaking/{uid} {
    //   allow read: if request.auth != null;
    //   allow write: if request.auth != null && request.auth.uid == uid;
    // }
    // match /matches/{matchId} {
    //   allow read: if request.auth != null &&
    //     (resource.data.p1Uid == request.auth.uid || resource.data.p2Uid == request.auth.uid);
    //   allow create: if request.auth != null;
    //   allow update: if request.auth != null &&
    //     (resource.data.p1Uid == request.auth.uid || resource.data.p2Uid == request.auth.uid);
    //
    //   // Hidden-until-both-submitted round choices: you can always read/
    //   // write your OWN choice doc. You can only read your OPPONENT's
    //   // choice doc once your own choice doc for that round already
    //   // exists — this is what prevents peeking before you've committed.
    //   match /rounds/{roundNum}/choices/{choiceUid} {
    //     allow read: if request.auth != null && (
    //       request.auth.uid == choiceUid ||
    //       exists(/databases/$(database)/documents/matches/$(matchId)/rounds/$(roundNum)/choices/$(request.auth.uid))
    //     );
    //     allow create: if request.auth != null && request.auth.uid == choiceUid;
    //     allow update, delete: if false; // choices are write-once per round
    //   }
    // }

    // ============================================================
    // PHASE 4 — Friend-match invites (uncomment when it ships)
    // ============================================================
    // match /matchInvites/{inviteId} {
    //   allow read: if request.auth != null &&
    //     (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    //   allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
    //   allow update: if request.auth != null &&
    //     (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    // }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
